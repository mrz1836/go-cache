# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-cache
# Load Order: 90 (loaded after all tool defaults, overrides earlier files)
#
# This file contains project-specific configuration that overrides defaults from
# core (00-core.env) and tool-specific (10-*.env, 20-*.env) configuration files.
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (overrides internal default to use codecov)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/,docs/

# ================================================================================================
# 🔧 REDIS SERVICE CONFIGURATION
# ================================================================================================

# Redis Service
ENABLE_REDIS_SERVICE=true
REDIS_SERVICE_MODE=always

# ================================================================================================
# 🛡️ CVE EXCLUSIONS
# ================================================================================================

# Nancy and Mage X CVE Exclusions
NANCY_EXCLUDES=CVE-2026-24051,CVE-2026-34986,CVE-2026-39883,CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,CVE-2026-46595,CVE-2026-46597,CVE-2026-46598,CVE-2026-41178
MAGE_X_CVE_EXCLUDES=CVE-2026-24051,CVE-2026-34986,CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,CVE-2026-46595,CVE-2026-46597,CVE-2026-46598,CVE-2026-41178
